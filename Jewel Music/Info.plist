<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Allow Files app access to app's Documents directory -->
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<!-- Expose Documents via Finder/iTunes file sharing -->
	<key>UIFileSharingEnabled</key>
	<true/>
	<!-- If using document types later, add CFBundleDocumentTypes entries -->
</dict>
</plist>
